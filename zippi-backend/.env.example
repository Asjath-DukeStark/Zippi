# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Storage bucket for uploaded images (created automatically)
STORAGE_BUCKET=zippi-uploads

# Comma-separated origins, or omit for *
# CORS_ORIGINS=https://zippi.app,https://admin.zippi.app

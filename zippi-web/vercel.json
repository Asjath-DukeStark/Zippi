{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://zippi-production-a7c1.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
